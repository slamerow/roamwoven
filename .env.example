NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TRIP_PRICE_ID=
OPENAI_API_KEY=
OPENAI_EXTRACTION_MODEL=gpt-5.4-mini
OPENAI_OCR_MODEL=gpt-5.6-luna
OPENAI_EXTRACTION_MAX_INPUT_CHARS=120000
OPENAI_EXTRACTION_MAX_OUTPUT_TOKENS=12000
OPENAI_OCR_IMAGE_DETAIL=high
OPENAI_OCR_MAX_OUTPUT_TOKENS=16000
OPENAI_OCR_MAX_FILES_PER_RUN=20
OPENAI_OCR_PDF_BATCH_PAGES=4
# RW-EVD-001 bounded recovery call (one excerpt-only re-ask per build).
# Model defaults to OPENAI_EXTRACTION_MODEL when unset.
OPENAI_RECOVERY_MODEL=
OPENAI_RECOVERY_MAX_INPUT_CHARS=16000
OPENAI_RECOVERY_MAX_OUTPUT_TOKENS=8000
OPENAI_RECOVERY_MAX_LINES=60
# Geocoding verification lane (Arc B): disabled unless the API key is set.
# Hard per-trip lookup budget; fail-soft; verified coordinates are used ONLY
# to verify grouping proximity and never change intent/date/city.
GEOCODE_VERIFICATION_API_KEY=
GEOCODE_VERIFICATION_ENDPOINT=https://maps.googleapis.com/maps/api/geocode/json
GEOCODE_VERIFICATION_MAX_LOOKUPS=15
GEOCODE_VERIFICATION_TIMEOUT_MS=4000
ROAMWOVEN_ENABLE_AI_EXTRACTION=false
ROAMWOVEN_EXTRACTION_ALLOWED_TRIP_IDS=

# Vercel Cron authentication for scheduled jobs (cleanup of abandoned unpaid materials)
CRON_SECRET=
